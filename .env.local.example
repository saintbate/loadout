# Neon Postgres — copy the pooled connection string from the Neon dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Clerk — from the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Optional Clerk redirects (uncomment to override defaults).
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Anthropic — used by the planner.
ANTHROPIC_API_KEY="sk-ant-..."

# Admin gating — your Clerk user_id (find it in the Clerk dashboard or via
# `console.log(auth().userId)` after signing in). The /admin route is
# 404'd for everyone else.
ADMIN_CLERK_USER_ID="user_..."
